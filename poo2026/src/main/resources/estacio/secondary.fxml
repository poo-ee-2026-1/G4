<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      spacing="20"

      xmlns="http://javafx.com/javafx/21"

      xmlns:fx="http://javafx.com/fxml/1"

      fx:controller="estacio.SecondaryController">

    <children>

        <Label text="VAGAS"/>

        <GridPane hgap="20"
                  vgap="20"
                  alignment="CENTER">

            <children>

                <Button fx:id="vaga1"
                        prefWidth="200"
                        prefHeight="120"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="0"/>

                <Button fx:id="vaga2"
                        prefWidth="200"
                        prefHeight="120"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="0"/>

                <Button fx:id="vaga3"
                        prefWidth="200"
                        prefHeight="120"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="1"/>

                <Button fx:id="vaga4"
                        prefWidth="200"
                        prefHeight="120"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="1"/>

            </children>

        </GridPane>

        <Button text="Voltar"
                onAction="#voltar"/>

    </children>

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

</VBox>